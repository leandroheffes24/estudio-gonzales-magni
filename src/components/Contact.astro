---
import { site, waLink, telLink, mapEmbedUrl, mapLink, fullAddress } from '../data/site';

const fieldClass =
  'w-full rounded-xl border border-grafito-200 bg-arena-50 px-4 py-3 text-grafito-900 placeholder:text-grafito-400 transition-colors duration-300 focus:border-terracota-500 focus:outline-none focus:ring-2 focus:ring-terracota-500/30';
---

<section id="contacto" class="scroll-mt-24 bg-arena-100/40 py-section">
  <div class="container-editorial">
    <div class="grid gap-12 lg:grid-cols-12 lg:gap-16">
      <!-- Intro + métodos directos -->
      <div class="lg:col-span-5" data-reveal>
        <div class="flex items-center gap-4">
          <span class="section-index">07</span>
          <span class="eyebrow">Contacto</span>
        </div>
        <h2 class="mt-5 font-serif text-fluid-3xl font-medium text-grafito-950">
          Contanos qué necesitás
        </h2>
        <p class="mt-6 max-w-md text-fluid-base leading-relaxed text-grafito-600">
          No hace falta que tengas todo claro ni ordenado. Escribinos en pocas líneas y nosotros te
          guiamos desde ahí. La primera consulta es sin compromiso.
        </p>

        <!-- Métodos directos -->
        <div class="mt-8 space-y-3">
          <a
            href={waLink()}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-4 rounded-2xl border border-grafito-200/70 bg-arena-50 p-4 transition-all duration-300 hover:-translate-y-0.5 hover:border-pino-400 hover:shadow-soft"
          >
            <span class="grid h-11 w-11 shrink-0 place-items-center rounded-full bg-pino-600 text-arena-50">
              <svg viewBox="0 0 24 24" class="h-6 w-6" fill="currentColor" aria-hidden="true">
                <path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 018.413 3.488 11.82 11.82 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26l-.999 3.648 3.978-1.039zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"></path>
              </svg>
            </span>
            <span>
              <span class="block text-sm text-grafito-500">Respuesta más rápida</span>
              <span class="block font-medium text-grafito-950">Escribinos por WhatsApp</span>
            </span>
          </a>

          <a
            href={`mailto:${site.contact.email}`}
            data-copy-email
            class="group flex items-center gap-4 rounded-2xl border border-grafito-200/70 bg-arena-50 p-4 transition-all duration-300 hover:-translate-y-0.5 hover:border-terracota-400 hover:shadow-soft"
          >
            <span class="grid h-11 w-11 shrink-0 place-items-center rounded-full bg-grafito-900 text-arena-50">
              <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <rect x="3" y="5" width="18" height="14" rx="2" />
                <path d="M3.5 6.5l8.5 6 8.5-6" />
              </svg>
            </span>
            <span>
              <span class="block text-sm text-grafito-500">Por correo</span>
              <span class="block font-medium text-grafito-950">{site.contact.email}</span>
            </span>
          </a>
        </div>
      </div>

      <!-- Formulario -->
      <div class="lg:col-span-7" data-reveal>
        <div class="rounded-[2rem] border border-grafito-200/70 bg-arena-50 p-6 shadow-soft sm:p-9">
          <form id="contact-form" action={site.contact.formEndpoint} method="POST" class="space-y-5" novalidate>
            <!-- Honeypot anti-spam (oculto) -->
            <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

            <div class="grid gap-5 sm:grid-cols-2">
              <label class="block">
                <span class="mb-2 block text-sm font-medium text-grafito-700">Nombre *</span>
                <input type="text" name="nombre" required autocomplete="name" placeholder="Cómo te llamás" class={fieldClass} />
              </label>
              <label class="block">
                <span class="mb-2 block text-sm font-medium text-grafito-700">Teléfono</span>
                <input type="tel" name="telefono" autocomplete="tel" placeholder="Opcional" class={fieldClass} />
              </label>
            </div>

            <label class="block">
              <span class="mb-2 block text-sm font-medium text-grafito-700">Email *</span>
              <input type="email" name="email" required autocomplete="email" placeholder="tucorreo@ejemplo.com" class={fieldClass} />
            </label>

            <label class="block">
              <span class="mb-2 block text-sm font-medium text-grafito-700">¿En qué te podemos ayudar? *</span>
              <textarea name="mensaje" required rows="5" placeholder="Contanos brevemente tu situación o tu consulta." class={`${fieldClass} resize-y`}></textarea>
            </label>

            <div class="flex flex-col gap-4 pt-1 sm:flex-row sm:items-center sm:justify-between">
              <button id="submit-btn" type="submit" class="btn btn-primary w-full sm:w-auto">
                Enviar consulta
                <span class="btn-arrow" aria-hidden="true">→</span>
              </button>
              <p class="text-xs leading-relaxed text-grafito-400 sm:max-w-[16rem]">
                Tus datos se usan sólo para responderte. Nada de spam.
              </p>
            </div>

            <p id="form-status" role="status" aria-live="polite" class="hidden rounded-xl px-4 py-3 text-sm"></p>
          </form>
        </div>
      </div>
    </div>

    <!-- Mapa a ancho completo -->
    <div class="mt-10 lg:mt-14" data-reveal>
      <div class="overflow-hidden rounded-[2rem] border border-grafito-200/70 shadow-soft">
        <iframe
          src={mapEmbedUrl()}
          title={`Ubicación de ${site.name} en San Carlos de Bariloche`}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
          class="block h-64 w-full border-0 sm:h-72 lg:h-80"
        ></iframe>
      </div>
      <div class="mt-3 flex flex-col gap-1 text-sm text-grafito-500 sm:flex-row sm:items-start sm:justify-between sm:gap-4">
        <address class="not-italic leading-relaxed">{fullAddress()}</address>
        <a href={mapLink()} target="_blank" rel="noopener noreferrer" class="link-underline shrink-0 font-medium text-terracota-700">
          Cómo llegar
        </a>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ endpoint: site.contact.formEndpoint, waNumber: site.contact.whatsapp, placeholder: 'https://formspree.io/f/your-form-id' }}>
  const form = document.getElementById('contact-form');
  const statusEl = document.getElementById('form-status');
  const btn = document.getElementById('submit-btn');

  function setStatus(kind, msg) {
    if (!statusEl) return;
    statusEl.textContent = msg;
    statusEl.className =
      'rounded-xl px-4 py-3 text-sm ' +
      (kind === 'success'
        ? 'bg-pino-100 text-pino-800'
        : kind === 'error'
          ? 'bg-terracota-100 text-terracota-800'
          : 'bg-arena-200 text-grafito-700');
  }

  if (form) {
    form.addEventListener('submit', async (e) => {
      // Validación nativa: el evento submit sólo dispara si los campos requeridos son válidos
      const data = new FormData(form);

      // Honeypot: si está completo, es un bot → ignorar en silencio
      if (data.get('_gotcha')) {
        e.preventDefault();
        return;
      }

      // Sin endpoint real configurado → derivar la consulta a WhatsApp
      if (!endpoint || endpoint === placeholder) {
        e.preventDefault();
        const msg =
          `Hola, soy ${data.get('nombre') || ''}.\n` +
          `Email: ${data.get('email') || ''}\n` +
          (data.get('telefono') ? `Tel: ${data.get('telefono')}\n` : '') +
          `Consulta: ${data.get('mensaje') || ''}`;
        window.open(`https://wa.me/${waNumber}?text=${encodeURIComponent(msg)}`, '_blank', 'noopener');
        setStatus('info', 'Te llevamos a WhatsApp para enviar tu consulta. ¡Gracias!');
        return;
      }

      // Envío real vía fetch (la persona no abandona la página)
      e.preventDefault();
      if (btn) {
        btn.setAttribute('disabled', 'true');
        btn.textContent = 'Enviando…';
      }
      setStatus('info', 'Enviando tu consulta…');
      try {
        const res = await fetch(endpoint, {
          method: 'POST',
          body: data,
          headers: { Accept: 'application/json' },
        });
        if (res.ok) {
          form.reset();
          setStatus('success', '¡Gracias! Recibimos tu consulta y te respondemos a la brevedad.');
        } else {
          setStatus('error', 'No pudimos enviar el formulario. Probá de nuevo o escribinos por WhatsApp.');
        }
      } catch (err) {
        setStatus('error', 'Hubo un problema de conexión. Probá por WhatsApp y lo resolvemos.');
      } finally {
        if (btn) {
          btn.removeAttribute('disabled');
          btn.textContent = 'Enviar consulta';
        }
      }
    });
  }
</script>
