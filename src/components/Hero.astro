---
import { Image } from 'astro:assets';
import { site, waLink } from '../data/site';
import heroPortrait from '../assets/placeholders/hero-portrait.jpg';
---

<section id="inicio" class="relative pt-6 sm:pt-7">
  <div class="container-editorial pb-14 sm:pb-20 lg:pb-24">
    <!-- Cabecera tipo masthead editorial -->
    <div class="flex items-center justify-between gap-4 border-b hairline pb-5">
      <span class="eyebrow">Estudio contable y jurídico</span>
      <span class="text-right text-[0.68rem] font-medium uppercase tracking-eyebrow text-grafito-400 sm:text-xs">
        San&nbsp;Carlos de Bariloche · Río&nbsp;Negro
      </span>
    </div>

    <!-- Titular: la tipografía como protagonista -->
    <h1
      class="mt-8 max-w-4xl font-serif text-fluid-4xl font-medium leading-[1.05] text-grafito-950 motion-safe:animate-fade-up sm:mt-10"
    >
      Asesoría contable y jurídica en <em class="not-italic text-terracota-700">Bariloche</em><span
        class="text-grafito-400"
      > para empresas y personas</span>
    </h1>

    <!-- Banda editorial con reglas de columna (estilo diario) -->
    <div class="mt-8 grid gap-8 border-t hairline pt-8 sm:mt-10 lg:grid-cols-12 lg:gap-0">
      <!-- Bajada -->
      <div class="lg:col-span-5 lg:pr-10">
        <p class="max-w-md text-fluid-lg leading-relaxed text-grafito-600">
          Resolvemos tus consultas impositivas, contables, laborales y jurídicas del día a día (monotributo, sueldos,
          impuestos y cierres) con respuestas claras y a tiempo.
        </p>
      </div>

      <!-- Acciones -->
      <div class="lg:col-span-4 lg:border-l lg:border-grafito-200/70 lg:px-10">
        <div class="flex flex-col gap-3">
          <a href="#contacto" class="btn btn-primary w-full">
            Dejanos tu consulta
            <span class="btn-arrow" aria-hidden="true">→</span>
          </a>
          <a href={waLink()} target="_blank" rel="noopener noreferrer" class="btn btn-whatsapp w-full">
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true">
              <path
                d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 018.413 3.488 11.82 11.82 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26l-.999 3.648 3.978-1.039zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"
              ></path>
            </svg>
            Escribir por WhatsApp
          </a>
        </div>
        <p class="mt-4 text-xs leading-relaxed text-grafito-400">
          Primera consulta sin compromiso · online o presencial.
        </p>
      </div>

      <!-- Ficha / byline humano (no un bloque de imagen genérico) -->
      <div class="lg:col-span-3 lg:border-l lg:border-grafito-200/70 lg:pl-10">
        <figure class="flex items-center gap-3">
          <Image
            src={heroPortrait}
            alt={`${site.owner.name}, contadora y abogada del estudio`}
            width={120}
            height={120}
            loading="eager"
            class="h-14 w-14 shrink-0 rounded-full object-cover ring-1 ring-grafito-900/10"
          />
          <figcaption>
            <span class="block text-[0.68rem] uppercase tracking-eyebrow text-grafito-400">Te atiende</span>
            <span class="mt-0.5 block font-serif text-lg leading-tight text-grafito-950">{site.owner.name}</span>
          </figcaption>
        </figure>
        <p class="mt-3 text-xs leading-relaxed text-grafito-500">Contadora pública y abogada</p>
      </div>
    </div>
  </div>
</section>
