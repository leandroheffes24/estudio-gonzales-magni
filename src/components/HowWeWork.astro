---
import SectionHeader from './SectionHeader.astro';

const steps = [
  {
    title: 'Contacto',
    text: 'Nos escribís por WhatsApp o el formulario y nos contás tu situación. Sin compromiso y sin formalismos.',
  },
  {
    title: 'Análisis',
    text: 'Estudiamos tu caso a fondo: revisamos números, condición fiscal y qué necesitás realmente.',
  },
  {
    title: 'Respuesta y plan',
    text: 'Te damos una respuesta clara y un plan de acción concreto, con costos transparentes desde el inicio.',
  },
  {
    title: 'Acompañamiento',
    text: 'Quedamos a tu lado para los vencimientos, las dudas y las decisiones que vayan apareciendo.',
  },
];
---

<section id="proceso" class="scroll-mt-24 bg-grafito-950 py-section text-arena-200">
  <div class="container-editorial">
    <SectionHeader
      data-reveal
      index="03"
      eyebrow="Cómo trabajamos"
      title="Un camino simple, de principio a fin"
      intro="Nada de procesos eternos ni vocabulario imposible. Así es trabajar con nosotros, paso a paso."
      tone="dark"
    />

    <ol class="relative mt-16 grid gap-x-8 gap-y-12 md:grid-cols-4" data-reveal-stagger>
      <!-- Línea conectora horizontal (escritorio) -->
      <span aria-hidden="true" class="absolute inset-x-8 top-8 hidden border-t border-dashed border-arena-50/20 md:block"></span>

      {
        steps.map((step, i) => (
          <li class="group relative flex gap-5 md:flex-col md:gap-0" data-reveal>
            {/* Línea conectora vertical (móvil) */}
            {i < steps.length - 1 && (
              <span
                aria-hidden="true"
                class="absolute bottom-[-3rem] left-8 top-[4.5rem] w-px border-l border-dashed border-arena-50/20 md:hidden"
              />
            )}

            <div class="relative z-10 grid h-16 w-16 shrink-0 place-items-center rounded-full bg-grafito-900 font-serif text-2xl text-arena-50 ring-1 ring-arena-50/15 transition-all duration-500 ease-out-expo group-hover:scale-105 group-hover:bg-terracota-600 group-hover:ring-terracota-400/50">
              {String(i + 1).padStart(2, '0')}
            </div>

            <div class="md:mt-7">
              <p class="text-xs font-semibold uppercase tracking-eyebrow text-terracota-300">Paso {i + 1}</p>
              <h3 class="mt-2 font-serif text-fluid-xl font-medium text-arena-50">{step.title}</h3>
              <p class="mt-3 max-w-xs leading-relaxed text-arena-300">{step.text}</p>
            </div>
          </li>
        ))
      }
    </ol>

    <div class="mt-16 flex flex-col items-center gap-5 border-t border-arena-50/10 pt-10 text-center sm:flex-row sm:justify-between sm:text-left" data-reveal>
      <p class="max-w-md text-fluid-lg text-arena-200">
        El primer paso es una charla. El resto lo resolvemos nosotros.
      </p>
      <a href="#contacto" class="btn btn-on-dark shrink-0">
        Empezar por el paso 1
        <span class="btn-arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>
