---
interface Props {
  index?: string;
  eyebrow: string;
  title?: string;
  intro?: string;
  align?: 'left' | 'center';
  tone?: 'light' | 'dark';
  class?: string;
  [key: string]: unknown;
}

const {
  index,
  eyebrow,
  title,
  intro,
  align = 'left',
  tone = 'light',
  class: extra = '',
  ...rest
} = Astro.props;

const dark = tone === 'dark';
---

<header
  {...rest}
  class:list={[
    'max-w-3xl',
    align === 'center' && 'mx-auto text-center',
    extra,
  ]}
>
  <div class:list={['flex items-center gap-4', align === 'center' && 'justify-center']}>
    {index && <span class="section-index">{index}</span>}
    <span class:list={['eyebrow', dark && 'eyebrow--light']}>{eyebrow}</span>
  </div>

  <h2
    class:list={[
      'mt-5 font-serif text-fluid-3xl font-medium',
      dark ? 'text-arena-50' : 'text-grafito-950',
    ]}
  >
    <slot name="title">{title}</slot>
  </h2>

  {
    intro && (
      <p class:list={['mt-6 text-fluid-lg leading-relaxed', dark ? 'text-arena-200' : 'text-grafito-600']}>
        {intro}
      </p>
    )
  }
</header>
