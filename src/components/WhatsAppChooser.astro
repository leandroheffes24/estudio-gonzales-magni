---
import { site } from '../data/site';

const lines = site.whatsappLines;
const waPath =
  'M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 018.413 3.488 11.82 11.82 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26l-.999 3.648 3.978-1.039zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z';
---

<dialog id="wa-chooser" class="wa-dialog" aria-labelledby="wa-chooser-title">
  <div class="relative p-6 sm:p-8">
    <button
      type="button"
      data-wa-close
      aria-label="Cerrar"
      class="absolute right-4 top-4 grid h-9 w-9 place-items-center rounded-full text-grafito-400 transition-colors hover:bg-grafito-100 hover:text-grafito-900"
    >
      <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
        <path d="M6 6l12 12M18 6L6 18" />
      </svg>
    </button>

    <div class="flex items-center gap-2.5">
      <span class="grid h-9 w-9 place-items-center rounded-full bg-pino-600 text-arena-50">
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true"><path d={waPath} /></svg>
      </span>
      <span class="text-xs font-semibold uppercase tracking-eyebrow text-pino-700">WhatsApp</span>
    </div>

    <h2 id="wa-chooser-title" class="mt-4 font-serif text-fluid-xl font-medium text-grafito-950">
      ¿Sobre qué querés consultar?
    </h2>
    <p class="mt-2 text-sm leading-relaxed text-grafito-500">
      Elegí el área y te derivamos con la persona indicada.
    </p>

    <div class="mt-6 flex flex-col gap-3">
      {
        lines.map((line) => (
          <a
            class="wa-opt group flex items-center gap-4 rounded-2xl border border-grafito-200/80 bg-arena-100/40 p-4 transition-all duration-300 hover:-translate-y-0.5 hover:border-pino-400 hover:bg-arena-100 hover:shadow-soft"
            data-number={line.number}
            href={`https://wa.me/${line.number}`}
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="grid h-11 w-11 shrink-0 place-items-center rounded-full bg-pino-600 text-arena-50 transition-colors group-hover:bg-pino-700">
              <svg viewBox="0 0 24 24" class="h-6 w-6" fill="currentColor" aria-hidden="true">
                <path d={waPath} />
              </svg>
            </span>
            <span class="min-w-0">
              <span class="block font-serif text-base text-grafito-950">{line.label}</span>
              <span class="block text-sm text-grafito-500">{line.display}</span>
            </span>
            <span
              class="ml-auto shrink-0 text-grafito-300 transition-all duration-300 group-hover:translate-x-1 group-hover:text-pino-600"
              aria-hidden="true"
            >
              →
            </span>
          </a>
        ))
      }
    </div>
  </div>
</dialog>

<style>
  .wa-dialog {
    width: min(92vw, 30rem);
    margin: auto;
    padding: 0;
    color: #1f1c19;
    background: #faf7f1;
    border: 1px solid #cfcbc3;
    border-radius: 1.75rem;
    box-shadow: 0 2px 4px rgba(19, 17, 16, 0.05), 0 30px 60px -24px rgba(19, 17, 16, 0.4);
  }
  .wa-dialog::backdrop {
    background: rgba(19, 17, 16, 0.5);
    backdrop-filter: blur(3px);
  }

  @media (prefers-reduced-motion: no-preference) {
    .wa-dialog {
      opacity: 0;
      transform: translateY(10px) scale(0.98);
      transition: opacity 0.28s cubic-bezier(0.16, 1, 0.3, 1), transform 0.28s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .wa-dialog[open] {
      opacity: 1;
      transform: none;
    }
    @starting-style {
      .wa-dialog[open] {
        opacity: 0;
        transform: translateY(10px) scale(0.98);
      }
    }
  }
</style>

<script>
  const dialog = document.getElementById('wa-chooser') as HTMLDialogElement | null;

  if (dialog) {
    const opts = Array.from(dialog.querySelectorAll('.wa-opt')) as HTMLAnchorElement[];

    const openChooser = (message: string) => {
      opts.forEach((a) => {
        const n = a.getAttribute('data-number');
        a.href = 'https://wa.me/' + n + (message ? '?text=' + encodeURIComponent(message) : '');
      });
      if (typeof dialog.showModal === 'function') dialog.showModal();
      else dialog.setAttribute('open', '');
    };

    // Intercepta el clic en CUALQUIER enlace de WhatsApp del sitio y abre el selector,
    // conservando el mensaje pre-cargado (parámetro ?text=) de cada contexto.
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (!target || !target.closest) return;
      const a = target.closest('a[href*="wa.me"], a[href*="api.whatsapp.com"]') as HTMLAnchorElement | null;
      if (!a || a.closest('#wa-chooser')) return; // ignora los propios botones del selector
      e.preventDefault();
      let msg = '';
      try {
        msg = new URL(a.href).searchParams.get('text') || '';
      } catch (_) {}
      openChooser(msg);
    });

    // Cerrar: clic en el fondo, botón de cerrar o al elegir una opción
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });
    dialog.querySelectorAll('[data-wa-close]').forEach((b) => b.addEventListener('click', () => dialog.close()));
    opts.forEach((a) => a.addEventListener('click', () => setTimeout(() => dialog.close(), 10)));
  }
</script>
